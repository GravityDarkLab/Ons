# ─── Database ────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=matching

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key — must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars_generated_by_openssl_rand_hex_32

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT secret — use a long random string.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_long_random_secret

# Admin credentials (v1 — single admin, stored in env)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
