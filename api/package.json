{
  "name": "ons-api",
  "version": "1.0.0",
  "private": true,
  "author": "Achraf Labidi <labidiachraf6@gmail.com> (https://github.com/GravityDarkLab)",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=.env.dev  run --watch src/server.ts",
    "dev:test": "bun --env-file=.env.test run --watch src/server.ts",
    "dev:prod": "bun --env-file=.env.prod run --watch src/server.ts",
    "start": "bun --env-file=.env      run         src/server.ts",
    "seed": "bun run src/seeds/questionnaire.seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test --preload ./src/__tests__/setup.ts ./src/__tests__",
    "test:watch": "bun test --watch --preload ./src/__tests__/setup.ts ./src/__tests__"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-validator": "^0.8.0",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "js-yaml": "^4.1.1",
    "mongodb": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^6.0.3"
  }
}
