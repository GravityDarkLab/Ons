# Copy this file to create per-environment configs:
#   cp .env.example .env.dev
#   cp .env.example .env.test
#   cp .env.example .env.prod
#
# This file is also used as the --env-file for docker compose:
#   docker compose --env-file api/.env.dev up --build
#
# Then seed with:
#   bun run seed           ← interactive (choose questionnaire / applicants / admin)
#
# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (no Docker):  mongodb://ons_app:<password>@localhost:27017/ons?authSource=admin
# docker compose (dev):   mongodb://ons_app:<password>@ons-mongo:27017/ons?authSource=admin
# Production (Atlas/VPS): mongodb+srv://...  or  mongodb://ons_app:<password>@<host>:27017/ons
MONGODB_URI=mongodb://ons_app:<password>@ons-mongo:27017/ons?authSource=admin
MONGODB_DB_NAME=ons

# ─── Encryption ───────────────────────────────────────────────────────────────
# AES-256-GCM key — must be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace_with_64_hex_chars_generated_by_openssl_rand_hex_32

# HMAC secret for submission keys — prevents questionnaire version enumeration.
# Generate with: openssl rand -hex 32
FORM_SECRET=replace_with_64_hex_chars_generated_by_openssl_rand_hex_32

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT secret — use a long random string.
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_long_random_secret
# Format used for time span should be a number followed by a unit, such as "5 minutes" or "1 day".
# Valid units are: "sec", "secs", "second", "seconds", "s", "minute", "minutes", "min", "mins", "m", "hour", "hours", "hr", "hrs", "h", "day", "days", "d", "week", "weeks", "w", "year", "years", "yr", "yrs", and "y".
ADMIN_JWT_EXPIRY=8h
# Applicant portal session length — separate from ADMIN_JWT_EXPIRY above since
# admins and applicants have very different re-login tolerance. Same format.
APPLICANT_JWT_EXPIRY=30d

# ─── Account deletion ──────────────────────────────────────────────────────────
# Days an inactive applicant's personal data is retained before permanent purge.
# Defaults to 180 if unset.
DELETION_GRACE_DAYS=180

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Full base URL logged on startup. Leave empty in dev (defaults to http://localhost:<PORT>).
# Set in test/prod: PUBLIC_URL=https://api.domain.com
PUBLIC_URL=

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Embedding provider (only needed for the "embedding-cosine" algorithm) ────
#
# EMBEDDING_PROVIDER=openai   → OpenAI embeddings API
#   OPENAI_API_KEY=sk-...
#   EMBEDDING_MODEL=text-embedding-3-small   # or text-embedding-3-large
#
# EMBEDDING_PROVIDER=local    → Any OpenAI-compatible local server
#   EMBEDDING_BASE_URL=http://localhost:1234/v1   # LM Studio
#   EMBEDDING_BASE_URL=http://localhost:11434/v1  # Ollama
#   EMBEDDING_MODEL=text-embedding-embeddinggemma-300m          # or any other compatible model
#
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=
OPENAI_API_KEY=
EMBEDDING_BASE_URL=

# ─── AI chat (ice-breaker generation, match summaries, match rerank) ──────────
# Defaults to EMBEDDING_PROVIDER/EMBEDDING_BASE_URL above if left unset — set
# these only if you want chat completions to use a *different* backend than
# embeddings (e.g. local embeddings you've already cached + a hosted OpenAI
# chat model, or vice versa).
#
# CHAT_PROVIDER=openai   → OPENAI_API_KEY (same key as above) is required
# CHAT_PROVIDER=local    → CHAT_BASE_URL (or EMBEDDING_BASE_URL as a fallback)
#   CHAT_BASE_URL=http://localhost:1234/v1   # LM Studio
#   CHAT_BASE_URL=http://localhost:11434/v1  # Ollama
#
#   openai provider:  OPENAI_CHAT_MODEL=gpt-5.4-mini
#   local provider:   OPENAI_CHAT_MODEL=llama-3.2-3b-instruct  (whatever is loaded)
# Privacy note: with CHAT_PROVIDER=openai (or EMBEDDING_PROVIDER=openai when
# CHAT_PROVIDER is unset), free-text profile answers (lifestyle, deal
# breakers, etc. — never the Instagram handle) are sent to OpenAI to generate
# ice-breakers, match summaries, and rerank scores. Use a local provider to
# keep all profile text on infrastructure you control.
CHAT_PROVIDER=
CHAT_BASE_URL=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ─── Scheduled matching job ────────────────────────────────────────────────────
# Leave empty (or unset) to disable. Set to a number to enable periodic runs.
# Example: MATCHING_JOB_INTERVAL_HOURS=24  → run once a day
MATCHING_JOB_INTERVAL_HOURS=

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Shared login credential for all accounts created by `bun run seed:applicants`.
# Intentionally trivial — dev/test only. Defaults to "ons-dev-seed" if unset.
SEED_LOGIN=
# Admin seed credentials — used by `bun run seed` to create the initial admin account.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_admin_password

