{
  "name": "matching",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["api", "frontend"],
  "scripts": {
    "dev":          "bun run scripts/dev.ts",
    "dev:api":      "bun --cwd api run dev",
    "dev:frontend": "bun --cwd frontend run dev",
    "seed":         "bun run scripts/seed.ts",
    "build":        "bun run --filter '*' build",
    "typecheck":    "bunx tsc --noEmit -p tsconfig.json && bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0"
  }
}
