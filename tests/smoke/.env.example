# Smoke test configuration
# Copy to .env.smoke and fill in values, then:
#   bun --env-file=tests/smoke/.env.smoke test tests/smoke/

# URL of the running server (no trailing slash)
SMOKE_BASE_URL=http://localhost:3001

# Admin credentials (match ADMIN_USERNAME / ADMIN_PASSWORD in api/.env.dev)
SMOKE_ADMIN_USER=your_admin_username
SMOKE_ADMIN_PASS=your_admin_password

# MongoDB URI — required only for match-flow.smoke.ts
# Leave empty (or unset) to skip match-flow tests in CI
SMOKE_MONGO_URI=mongodb://localhost:27017/ons_dev
